# Security settings for pnpm
# Prevent installation of packages with known vulnerabilities
audit-level=moderate

# Use exact versions by default (no caret/tilde ranges)
# This ensures reproducible installs
save-exact=false

# Require pnpm 10 or higher
engine-strict=true

# Verify package integrity using lockfile
prefer-frozen-lockfile=true

# Allow build scripts to run (needed for sharp, esbuild, etc.)
# In non-interactive environments like Docker, scripts need explicit allowance
ignore-scripts=false

# Disable workspace protocol auto-fallback to reduce supply chain risk
workspace-root-fallback=false
